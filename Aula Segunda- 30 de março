export const validarEPreparar = (dados) => {
  if (!dados.nome) {
    throw new Error("O nome do material é obrigatório!");
  }
  return { ...dados, dataCriacao: new Date() };
};



import { validarEPreparar } from '../services/materialService.js';

export const cadastrarMaterial = (req, res) => {
  try {
    const materialPronto = validarEPreparar(req.body);
    
    res.status(201).send("Material salvo com sucesso!");
    
  } catch (erro) {
    res.status(400).send(erro.message);
  }
};

