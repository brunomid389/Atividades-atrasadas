import React from 'react';

const CardProduto = ({ titulo, descricao, corBotao, emPromocao }) => {

  const classeCustomizada = emPromocao === 'Sim' ? 'card-promo' : '';

  return (
    <div className={`card h-100 shadow-sm ${classeCustomizada}`} style={{ width: '18rem', margin: '10px' }}>
      <div className="card-body d-flex flex-column align-items-center text-center">
                <div className="bg-light mb-3 rounded" style={{ width: '100%', height: '150px' }}></div>

        <h5 className="card-title">{titulo}</h5>
        <p className="card-text text-muted small">{descricao}</p>

        {emPromocao === 'Sim' && (
          <span className="badge bg-danger mb-3">PROMOÇÃO!</span>
        )}

        <button className={`btn btn-${corBotao} mt-auto w-100`}>
          Comprar
        </button>
      </div>
    </div>
  );
};

export default CardProduto;

