/* Classe CSS própria para o card em promoção */
.card-promo {
  background-color: #fff5f5 !important; /* Um tom leve de vermelho/rosa */
  border: 2px solid #dc3545 !important;
  transform: scale(1.02); /* Dá um leve destaque visual */
  transition: all 0.3s ease;
}
