{
  "openapi": "3.0.0",
  "info": {
    "title": "API de Gerenciamento de Alunos",
    "description": "API para gerenciar alunos e suas turmas",
    "version": "1.0.0",
    "contact": {
      "name": "Suporte",
      "email": "suporte@escola.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Servidor de Desenvolvimento"
    }
  ],
  "paths": {
    "/alunos": {
      "get": {
        "summary": "Lista todos os alunos",
        "description": "Retorna uma lista de todos os alunos cadastrados. Pode ser filtrada por turma.",
        "tags": ["Alunos"],
        "parameters": [
          {
            "name": "turma",
            "in": "query",
            "description": "Filtrar alunos por turma (exemplo: 2A, 3B)",
            "required": false,
            "schema": {
              "type": "string",
              "example": "2A"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de alunos retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Aluno"
                  }
                },
                "example": [
                  {
                    "id": 1,
                    "nome": "João Silva",
                    "idade": 15,
                    "turma": "2A",
                    "email": "joao.silva@escola.com",
                    "matricula": "2024001"
                  },
                  {
                    "id": 2,
                    "nome": "Maria Santos",
                    "idade": 14,
                    "turma": "2A",
                    "email": "maria.santos@escola.com",
                    "matricula": "2024002"
                  }
                ]
              }
            }
          },
          "400": {
            "description": "Requisição inválida - parâmetros incorretos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "code": 400,
                  "message": "Parâmetro 'turma' inválido",
                  "details": "O formato da turma deve ser uma letra maiúscula seguida de um número (ex: 2A)"
                }
              }
            }
          }
        }
      }
    },
    "/alunos/{id}": {
      "get": {
        "summary": "Busca um aluno por ID",
        "description": "Retorna os dados de um aluno específico baseado no ID fornecido",
        "tags": ["Alunos"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID único do aluno",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Aluno encontrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Aluno"
                },
                "example": {
                  "id": 1,
                  "nome": "João Silva",
                  "idade": 15,
                  "turma": "2A",
                  "email": "joao.silva@escola.com",
                  "matricula": "2024001"
                }
              }
            }
          },
          "400": {
            "description": "Requisição inválida - ID em formato incorreto",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "code": 400,
                  "message": "ID inválido",
                  "details": "O ID deve ser um número inteiro positivo"
                }
              }
            }
          },
          "404": {
            "description": "Aluno não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                },
                "example": {
                  "code": 404,
                  "message": "Aluno não encontrado",
                  "details": "Não existe nenhum aluno cadastrado com o ID fornecido"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Aluno": {
        "type": "object",
        "required": ["id", "nome", "idade", "turma", "matricula"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "ID único do aluno",
            "example": 1
          },
          "nome": {
            "type": "string",
            "description": "Nome completo do aluno",
            "minLength": 3,
            "maxLength": 100,
            "example": "João Silva"
          },
          "idade": {
            "type": "integer",
            "description": "Idade do aluno em anos",
            "minimum": 6,
            "maximum": 18,
            "example": 15
          },
          "turma": {
            "type": "string",
            "description": "Turma do aluno (formato: número + letra)",
            "pattern": "^[1-9][A-Z]$",
            "example": "2A"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "E-mail do aluno",
            "example": "joao.silva@escola.com"
          },
          "matricula": {
            "type": "string",
            "description": "Número de matrícula do aluno",
            "pattern": "^[0-9]{7}$",
            "example": "2024001"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "integer",
            "description": "Código HTTP do erro",
            "example": 404
          },
          "message": {
            "type": "string",
            "description": "Mensagem de erro resumida",
            "example": "Aluno não encontrado"
          },
          "details": {
            "type": "string",
            "description": "Detalhes adicionais sobre o erro",
            "example": "Não existe nenhum aluno cadastrado com o ID fornecido"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Alunos",
      "description": "Endpoints relacionados ao gerenciamento de alunos"
    }
  ]
}

